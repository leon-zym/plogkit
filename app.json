{
  "expo": {
    "name": "PlogKit",
    "slug": "plogkit",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "plogkit",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.leonzym.plogkit",
      "supportsTablet": false
    },
    "android": {
      "package": "com.leonzym.plogkit",
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#F6F1E8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-dev-client",
        {
          "launchMode": "most-recent",
          "defaultLaunchURL": "http://localhost:8081",
          "android": {
            "defaultLaunchURL": "http://10.0.2.2:8081"
          }
        }
      ],
      "./plugins/with-dev-menu-preferences",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PlogKit to import the photos you choose.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": false,
          "savePhotosPermission": "Allow PlogKit to save exported images to Photos.",
          "granularPermissions": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F6F1E8",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
